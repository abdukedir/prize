generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  SUPERADMIN
  ADMIN
  EMPLOYEE
}

enum RoundStatus {
  OPEN
  CLOSED
}

enum GameType {
  NUMBERS
  EVEN_ODD
}

enum ParticipantStatus {
  ACTIVE
  WINNER
  LOST
  DISABLED
}

enum PrizeRank {
  FIRST
  SECOND
}

enum EvenOddSide {
  EVEN
  ODD
}

enum EvenOddRoomStatus {
  WAITING
  MATCHED
  COMPLETED
  CANCELLED
  REFUNDED
}

enum EvenOddRoundStatus {
  OPEN
  PUBLISHED
}

model Tenant {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  users        User[]
  participants Participant[]
  winners      Winner[]
  settings     Setting?
  rounds       GameRound[]
  evenOddRounds EvenOddRound[]
  evenOddRooms  EvenOddRoom[]
  evenOddBets   EvenOddBet[]
  entries      Entry[]
  reports      Report[]
  activityLogs ActivityLog[]
  createdAt    DateTime      @default(now())
}

model User {
  id           String        @id @default(cuid())
  tenantId     String
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name         String
  email        String        @unique
  password     String
  role         Role          @default(EMPLOYEE)
  disabled     Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  winners      Winner[]      @relation("SelectedBy")
  publishedEvenOddRounds EvenOddRound[] @relation("EvenOddPublishedBy")
  activityLogs ActivityLog[]

  @@index([tenantId, role])
}

model Participant {
  id              String            @id @default(cuid())
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fullName        String
  phoneNumber     String            @default("")
  amountDeposited Decimal           @db.Decimal(18, 2)
  balance         Decimal           @default(0) @db.Decimal(18, 2)
  status          ParticipantStatus @default(ACTIVE)
  createdById     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  entries         Entry[]
  winners         Winner[]
  evenOddBets     EvenOddBet[]

  @@index([tenantId, fullName])
  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model GameRound {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number    Int
  gameType  GameType    @default(NUMBERS)
  status    RoundStatus @default(OPEN)
  createdAt DateTime    @default(now())
  closedAt  DateTime?
  entries   Entry[]
  winners   Winner[]
  report    Report?

  @@unique([tenantId, number])
  @@index([tenantId, gameType, status])
}

model Entry {
  id             String      @id @default(cuid())
  tenantId       String
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  participantId  String
  participant    Participant @relation(fields: [participantId], references: [id], onDelete: Restrict)
  gameId         String
  game           GameRound   @relation(fields: [gameId], references: [id], onDelete: Cascade)
  selectedNumber Int
  ticketPrice    Decimal     @db.Decimal(12, 2)
  createdAt      DateTime    @default(now())

  @@unique([gameId, selectedNumber])
  @@index([tenantId, gameId])
}

model Winner {
  id            String      @id @default(cuid())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Restrict)
  prizeAmount   Decimal     @db.Decimal(12, 2)
  rateDeduction Decimal     @default(0) @db.Decimal(12, 2)
  prizeRank     PrizeRank   @default(FIRST)
  selectedById  String
  selectedBy    User        @relation("SelectedBy", fields: [selectedById], references: [id], onDelete: Restrict)
  roundId       String
  round         GameRound   @relation(fields: [roundId], references: [id], onDelete: Restrict)
  roundNumber   Int
  createdAt     DateTime    @default(now())

  @@unique([roundId, prizeRank])
  @@index([tenantId, createdAt])
}

model Setting {
  id                 String   @id @default(cuid())
  tenantId           String   @unique
  tenant             Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  adminFeePercentage Decimal  @default(10) @db.Decimal(5, 2)
  ticketPrice        Decimal  @default(200) @db.Decimal(12, 2)
  firstPrize         Decimal  @default(1000) @db.Decimal(12, 2)
  secondPrize        Decimal  @default(200) @db.Decimal(12, 2)
  winnerRate         Decimal  @default(0) @db.Decimal(12, 2)
  currency           String   @default("ETB")
  language           String   @default("en")
  theme              String   @default("light")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Report {
  id                  String     @id @default(cuid())
  tenantId            String
  tenant              Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  gameId              String?    @unique
  game                GameRound? @relation(fields: [gameId], references: [id], onDelete: SetNull)
  gameType            GameType
  gameCount           Int        @default(1)
  participantCount    Int
  ticketPrice         Decimal    @db.Decimal(12, 2)
  totalSales          Decimal    @db.Decimal(12, 2)
  firstPrizePaid      Decimal    @db.Decimal(12, 2)
  secondPrizePaid     Decimal    @db.Decimal(12, 2)
  winnerRateDeduction Decimal    @db.Decimal(12, 2)
  netIncome           Decimal    @db.Decimal(12, 2)
  createdAt           DateTime   @default(now())

  @@index([tenantId, createdAt])
}

model EvenOddRound {
  id              String             @id @default(cuid())
  tenantId        String
  tenant          Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  number          Int
  status          EvenOddRoundStatus @default(OPEN)
  selectedNumber  Int?
  winningSide     EvenOddSide?
  publishedById   String?
  publishedBy     User?              @relation("EvenOddPublishedBy", fields: [publishedById], references: [id], onDelete: SetNull)
  publishedByName String?
  publishedAt     DateTime?
  createdAt       DateTime           @default(now())
  rooms           EvenOddRoom[]

  @@unique([tenantId, number])
  @@index([tenantId, status])
}

model EvenOddRoom {
  id              String            @id @default(cuid())
  tenantId        String
  tenant          Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roundId         String
  round           EvenOddRound      @relation(fields: [roundId], references: [id], onDelete: Cascade)
  roomNumber      Int
  creatorSide     EvenOddSide
  targetAmount    Decimal           @db.Decimal(18, 2)
  status          EvenOddRoomStatus @default(WAITING)
  winnerSide      EvenOddSide?
  platformFee     Decimal           @default(0) @db.Decimal(18, 2)
  totalPayout     Decimal           @default(0) @db.Decimal(18, 2)
  matchedAt       DateTime?
  completedAt     DateTime?
  expiresAt       DateTime
  createdAt       DateTime          @default(now())
  bets            EvenOddBet[]

  @@unique([tenantId, roomNumber])
  @@index([tenantId, roundId, status])
}

model EvenOddBet {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roomId        String
  room          EvenOddRoom  @relation(fields: [roomId], references: [id], onDelete: Cascade)
  participantId String
  participant   Participant  @relation(fields: [participantId], references: [id], onDelete: Restrict)
  side          EvenOddSide
  amount        Decimal      @db.Decimal(18, 2)
  payout        Decimal      @default(0) @db.Decimal(18, 2)
  createdAt     DateTime     @default(now())

  @@index([tenantId, roomId])
  @@index([tenantId, participantId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action    String
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}
